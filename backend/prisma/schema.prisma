generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



enum Role {
  USER
  GUIDE
  PENDING_GUIDE
  ADMIN
}

enum PricePreference {
  BUDGET
  STANDARD
  PREMIUM
}

enum PricingType {
  FIXED
  RANGE
}

enum BookingStatus {
  NEGOTIATING
  PROPOSED
  ACCEPTED
  PAID
}

enum TourStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}


enum MessageType {
  TEXT
  ITINERARY_PROPOSAL
}


model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  name            String
  phone           String?
  role            Role            @default(USER)
  pricePreference PricePreference @default(STANDARD)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tours                Tour[]
  userConversations    Conversation[] @relation("UserConversations")
  guideConversations   Conversation[] @relation("GuideConversations")
  messages             Message[]
  travellerBookings  Booking[] @relation("TravellerBookings")
  guideBookings      Booking[] @relation("GuideBookings")

  @@map("users")
}

model Tour {
  id             String     @id @default(uuid())
  title          String
  description    String
  city           String
  guideId        String
  basePrice      Decimal    @default(0) @db.Decimal(12, 2)
  coverImageUrl  String?
  availableDates DateTime[]
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  

  guide          User           @relation(fields: [guideId], references: [id], onDelete: Cascade)
  activities     TourActivity[]
  photos         TourPhoto[]
  conversations  Conversation[]
  bookings  Booking[]

  @@map("tours")
}

model TourPhoto {
  id        String   @id @default(uuid())
  tourId    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_photos")
}

model TourActivity {
  id          String      @id @default(uuid())
  tourId      String
  name        String
  description String?
  pricingType PricingType @default(FIXED)
  fixedPrice  Decimal?    @db.Decimal(12, 2)
  minPrice    Decimal?    @db.Decimal(12, 2)
  maxPrice    Decimal?    @db.Decimal(12, 2)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())

  tour        Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_activities")
}

model Conversation {
  id            String        @id @default(uuid())
  userId        String
  guideId       String
  tourId        String
  bookingStatus BookingStatus @default(NEGOTIATING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  

  user     User      @relation("UserConversations",  fields: [userId],  references: [id], onDelete: Cascade)
  guide    User      @relation("GuideConversations", fields: [guideId], references: [id], onDelete: Cascade)
  tour     Tour      @relation(fields: [tourId],  references: [id], onDelete: Cascade)
  messages Message[]
  booking  Booking?

  @@unique([userId, guideId, tourId])
  @@map("conversations")
}

model Booking {
  id             String      @id @default(uuid())
  conversationId String?     @unique 
  tourId         String
  travellerId    String
  guideId        String
  status         TourStatus  @default(PLANNED)
  scheduledDate  DateTime
  agreedPrice    Decimal     @db.Decimal(12, 2)
  notes          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tour           Tour         @relation(fields: [tourId],         references: [id], onDelete: Cascade)
  traveller      User         @relation("TravellerBookings", fields: [travellerId], references: [id], onDelete: Cascade)
  guide          User         @relation("GuideBookings",     fields: [guideId],     references: [id], onDelete: Cascade)

  @@map("bookings")
}


model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  content        String
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId],       references: [id], onDelete: Cascade)

  @@map("messages")
}
